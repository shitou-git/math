        "azh": "早上好，宝贝。"
      },
      {
        "q": "Good morning, Dad!",
        "qzh": "爸爸早上好！",
        "a": "Good morning, son.",
        "azh": "早上好，儿子。"
      },
      {
        "q": "What's for breakfast?",
        "qzh": "早餐吃什么？",
        "a": "Milk and bread.",
        "azh": "牛奶和面包。"
      },
      {
        "q": "I'm hungry.",
        "qzh": "我饿了。",
