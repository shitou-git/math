  "classroom": {
    "name": {
      "en": "Classroom",
      "zh": "课堂对话"
    },
    "icon": "🏫",
    "dialogs": [
      {
        "q": "Good morning, class!",
        "qzh": "同学们早上好！",
        "a": "Good morning, teacher!",
        "azh": "老师早上好！"
      },
      {
        "q": "Stand up, please.",
        "qzh": "请起立。",
        "a": "Yes, Miss Li.",
        "azh": "好的，李老师。"
      },
      {
        "q": "Sit down, please.",
        "qzh": "请坐。",
        "a": "Thank you!",
        "azh": "谢谢！"
      },
      {
        "q": "Open your book, please.",
        "qzh": "请打开书。",
        "a": "Okay!",
        "azh": "好的！"
      },
      {
        "q": "Close your book.",
        "qzh": "合上书。",
        "a": "All right.",
        "azh": "好的。"
      },
      {
        "q": "Read after me, please.",
        "qzh": "请跟我读。",
        "a": "Okay!",
        "azh": "好的！"
      },
      {
        "q": "What's this?",
        "qzh": "这是什么？",
        "a": "It's a book.",
        "azh": "这是一本书。"
      },
      {
        "q": "What's that?",
        "qzh": "那是什么？",
        "a": "It's a pen.",
        "azh": "那是一支钢笔。"
      },
      {
        "q": "How do you spell it?",
        "qzh": "怎么拼写？",
        "a": "C-A-T, cat.",
        "azh": "C-A-T，cat。"
      },
      {
        "q": "Can you say it again?",
        "qzh": "你能再说一遍吗？",
        "a": "Sure! Cat.",
        "azh": "当然！Cat。"
      },
      {
        "q": "Who can answer this question?",
        "qzh": "谁能回答这个问题？",
        "a": "I can!",
        "azh": "我能！"
      },
      {
        "q": "Great job!",
        "qzh": "真棒！",
        "a": "Thank you!",
        "azh": "谢谢！"
      },
      {
        "q": "Let's start the class.",
        "qzh": "我们开始上课。",
        "a": "Okay!",
        "azh": "好的！"
      },
      {
        "q": "Class is over.",
        "qzh": "下课了。",
        "a": "Thank you, teacher!",
        "azh": "谢谢老师！"
      }
    ]
  },
  "daily": {
    "name": {
      "en": "Daily",
      "zh": "日常交流"
    },
    "icon": "🌞",
    "dialogs": [
      {
        "q": "Good morning, Mom!",
        "qzh": "妈妈早上好！",
