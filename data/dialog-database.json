        "azh": "我来了。"
      },
      {
        "q": "I'm home!",
        "qzh": "我回来了！",
        "a": "Welcome back!",
        "azh": "欢迎回来！"
      },
      {
        "q": "How was your day?",
        "qzh": "今天怎么样？",
        "a": "It was great!",
        "azh": "很棒！"
      },
      {
        "q": "Let's have dinner.",
        "qzh": "我们吃晚饭吧。",
        "a": "Okay!",
        "azh": "好的！"
      },
      {
        "q": "I'm tired.",
        "qzh": "我累了。",
        "a": "Let's go to bed.",
        "azh": "我们去睡觉吧。"
      },
      {
        "q": "Good night, Mom!",
        "qzh": "妈妈晚安！",
        "a": "Good night, sweetheart.",
        "azh": "晚安，宝贝。"
      },
      {
        "q": "I love you!",
        "qzh": "我爱你！",
        "a": "I love you too!",
        "azh": "我也爱你！"
      }
    ]
